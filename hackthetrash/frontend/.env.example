# Web client — copy to .env.local
# For Vercel production: leave NEXT_PUBLIC_API_URL unset so /api uses the same host (Next + Express serverless).
# For local split dev (Express on :4000): use the default below.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: only when running `next dev` without a separate backend (see docs/VERCEL.md).
# HACKTHETRASH_INTEGRATED_API=1
