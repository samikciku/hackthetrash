PORT=4000
DATABASE_URL=postgresql://user:pass@localhost:5432/hackthetrash
UPLOAD_DIR=./uploads

# JWT - REPLACE in production with a long random string (e.g. openssl rand -hex 64)
JWT_SECRET=please_replace_with_a_long_random_value_in_production
JWT_EXPIRES=12h

# Default admin user when DATABASE_URL is not set (in-memory mode).
# When using Postgres, seed an admin via npm run db:seed-admin.
ADMIN_EMAIL=admin@hackthetrash.org
ADMIN_PASSWORD=ChangeMe!2026

# CORS - comma separated list, or * for any (dev only)
CORS_ORIGINS=http://localhost:3000

# Vercel Blob (required on Vercel for photo uploads). Optional locally if using integrated Next API.
# BLOB_READ_WRITE_TOKEN=

# Integrated Next.js API only (local): memory multer + writes to ../backend/uploads
# HACKTHETRASH_INTEGRATED_API=1

# AI provider: mock | huggingface (HF only runs if AI_USE_HUGGINGFACE=1 as well)
AI_PROVIDER=mock
# AI_USE_HUGGINGFACE=1
HF_API_TOKEN=
HF_MODEL=google/vit-base-patch16-224
# HuggingFace HTTP timeout (ms). Inference can cold-start for a long time; without a cap the
# serverless function can hit Vercel maxDuration (see frontend/vercel.json).
AI_HF_FETCH_TIMEOUT_MS=12000
# Wall-clock cap per image (parallel moderation). Falls back to "uncertain" if exceeded.
AI_MODERATION_PER_IMAGE_BUDGET_MS=25000

# Public URL of the web client (used in outgoing email links).
PUBLIC_URL=http://localhost:3000

# Email transport: console (logs to stdout) | smtp
SMTP_TRANSPORT=console
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=HackTheTrash <no-reply@hackthetrash.org>
